{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "generate-api": "npx openapi-typescript http://localhost/docs/api.json -o resources/js/types/schema.d.ts",

    "core-push": "cd packages/box/nicole/core && git add . && git commit -m 'update: auto-sync core' && git push origin main",
    "core-commit": "cd packages/box/nicole/core && git add . && git commit && git push origin main",
    "core-pull": "git submodule update --remote --merge",
    "core-sync": "git add packages/box/nicole/core && git commit -m 'chore: bump core submodule pointer' && git push"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.0.1",
    "framer-motion": "^12.38.0",
    "laravel-vite-plugin": "^3.0.0",
    "lucide-react": "^1.16.0",
    "openapi-typescript": "^7.13.0",
    "puppeteer": "^25.2.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.4",
    "vaul": "^1.1.2",
    "vite": "^8.0.10",
    "zustand": "^5.0.13"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@inertiajs/react": "^3.0.3",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-imask": "^7.6.1",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "ziggy-js": "^2.6.2"
  }
}
